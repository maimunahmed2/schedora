rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public read access to the timetable data.
    // Restrict write access (create, update, delete) to authenticated users (CRs).
    match /timetable/{entryId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public read access to metadata (e.g., lastUpdated timestamp).
    // Restrict write access to authenticated users.
    match /metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
